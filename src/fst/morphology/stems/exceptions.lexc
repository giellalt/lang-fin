tietΟΛ+V:tietΟΛ           #    ;
tuta+V:tuta             #    ;
vilkkaa+V:vilkkaa       #    ;


!! The noun ruoka has irregular forms:
!!β²§ ruuassa:
!!β²§ ruuilla:
ruoka+N:ruua        NOUN_BACK_WEAK_SINGULARS   ;
ruoka+N:ruu         NOUN_BACK_WEAK_PLURALS ;

!! The adjective hyvΟΛ has heteroclitic comparative derivations too:
!!β²§ parempi:
!!β²§ paremmissa:
!!β²§ paras:
!!β²§ parhaat:
hyvΟΛ+A:pare                     ADJ_BACK_COMPARATIVE ;
hyvΟΛ+A+Superl:paras                ADJ_BACK_NOMINATIVE ;
hyvΟΛ+A+Superl:parhaa               ADJ_BACK_SINGULARS ;
hyvΟΛ+A+Superl:parha                ADJ_BACK_PLURALS ;
hyvΟΛ+A+Superl:paras                ADJ_BACK_PARTITIVE_TA ;
hyvΟΛ+A+Superl:parhaa               ADJ_BACK_ILLATIVE_SEEN ;
hyvΟΛ+A+Superl:parha                ADJ_BACK_GENITIVE_IDEN ;
hyvΟΛ+A+Superl+Use/NG:parha                ADJ_BACK_GENITIVE_ITTEN ;
hyvΟΛ+A+Superl:parha                ADJ_BACK_PARTITIVE_ITA ;
hyvΟΛ+A+Superl:parha                ADJ_BACK_ILLATIVE_ISIIN ;
hyvΟΛ+A:parha                    ADJ_BACK_SUPERLATIVE ;
hyvΟΛ+A+Der/sti+Adv:parhaiten    ADV_BACK_CLIT_OPT ;

!! Some of the nouns have archaic consonat stem forms left:
!!β²§ vuonna:
!!β²§ sydΟΛnnΟΛ:
!!β²§ jumalten:
!!β²§ sankarten:
vuosi+N+Sg+Ess+Use/NG:vuonna       NOUN_BACK_POSS_AN_OPT ;
sydΟΛn+N+Sg+Ess+Use/NG:sydΟΛnnΟΛ      NOUN_FRONT_POSS_Ο³N_OPT ;
jumala+N+Pl+Gen+Use/NG:jumalten    NOUN_BACK_CLIT_OPT ;
jumala+N+Pl+Gen+Use/NG:jumalten    NOUN_COMPOUND ;
sankari+N+Pl+Gen+Use/NG:sankarten  NOUN_FRONT_CLIT_OPT ;
sankari+N+Pl+Gen+Use/NG:sankarten  NOUN_COMPOUND ;

!! few verbs have shortened forms in standard spoken Finnish
!!β²§ meen:
!!β²§ tuut:
mennΟΛ+V+Act+Ind+Prs+Sg1+Dial/standard:meen       VERB_FRONT_CLIT_OPT    ;
mennΟΛ+V+Act+Ind+Prs+Sg2+Dial/standard:meet       VERB_FRONT_CLIT_OPT    ;
