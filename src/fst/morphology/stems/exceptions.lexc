tulla+V+Act+Imprt+Sg2+Dial/standard+Foc/s:tuus   VERB_BACK_CLIT_OPT       ;
panna+V+Act+Ind+Prs+Sg2+Dial/standard:paat       VERB_BACK_CLIT_OPT       ;
panna+V+Act+Imprt+Sg2+Dial/standard:paa          VERB_BACK_CLIT_OPT       ;
