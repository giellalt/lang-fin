mennΟΛ+V+Act+Imprt+Sg2+Dial/standard+Foc/s:mees   VERB_FRONT_CLIT_OPT    ;
tulla+V+Act+Ind+Prs+Sg1+Dial/standard:tuun       VERB_BACK_CLIT_OPT       ;
